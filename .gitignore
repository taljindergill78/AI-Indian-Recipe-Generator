# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# PyPI configuration file
.pypirc
/artifacts

# Model weights — adapter is on HuggingFace Hub; optimizer/RNG state not useful
*.safetensors
optimizer.pt
rng_state.pth
scheduler.pt

# Eval/train upload zips — scratch files, not source
ai-indian-recipe-*.zip

# Raw data — lives on HuggingFace Hub
data/raw/*.csv
data/raw/*.json
data/raw/*.parquet

# Intermediate pipeline outputs — regeneratable from the data pipeline scripts
data/processed/merged_cleaned.csv
data/processed/anupam_filtered.csv
data/processed/nf_analyst_filtered.csv
data/processed/prompt_response_pairs.csv
data/processed/train.csv
data/processed/val.csv

# Rowcheckpoint files — redundant copies of *_base_prompts.json (safety net only)
data/processed/*_rowcheckpoint.json

# Committed to GitHub (key evaluation results + test set for reproducibility):
#   candidate_baseline_comparison.csv  — model selection decision table
#   llama3_3b_base_metrics.json        — 3B aggregate metrics
#   llama3_1b_base_metrics.json        — 1B aggregate metrics
#   phi3_mini_base_metrics.json        — Phi3 aggregate metrics
#   llama3_3b_base_prompts.json        — 3B per-row results (3.4MB)
#   llama3_1b_base_prompts.json        — 1B per-row results (3.2MB)
#   phi3_mini_base_prompts.json        — Phi3 per-row results (3.1MB)
#   test.csv                           — 500-row test split for reproducibility

# Personal learning docs — not for public repo
docs/

# MLflow experiment tracking — generated at runtime, not source
mlruns/

# RunPod workspace snapshot — local training artifacts, not source
Workspace Runpod FineTuning/
